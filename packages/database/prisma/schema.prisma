datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CITIZEN
  ADMIN
  CANDIDATE
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum PromiseStatus {
  NOT_STARTED
  IN_PROGRESS
  PARTIALLY_FULFILLED
  FULFILLED
  STALLED
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            Role     @default(CITIZEN)
  constituency    String
  verified_status Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  issues ReportedIssue[]

  candidate_profile Candidate? @relation(fields: [candidate_id], references: [id])
  candidate_id      String?    @unique
}

model Candidate {
  id             String  @id @default(uuid())
  name           String
  party          String
  constituency   String
  education      String
  criminal_cases String?
  assets         String?
  liabilities    String?

  user User?

  manifestos Manifesto[]
  promises   Promise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Manifesto {
  id              String @id @default(uuid())
  party           String
  policy_category String
  policy_text     String

  candidate   Candidate? @relation(fields: [candidate_id], references: [id])
  candidate_id String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReportedIssue {
  id          String      @id @default(uuid())
  location    String
  issue_type  String
  description String
  status      IssueStatus @default(OPEN)

  reported_by      User   @relation(fields: [reported_by_uuid], references: [id])
  reported_by_uuid String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promise {
  id                  String        @id @default(uuid())
  description         String
  status              PromiseStatus @default(NOT_STARTED)
  progress_percentage Int           @default(0)

  candidate    Candidate @relation(fields: [candidate_id], references: [id])
  candidate_id String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
